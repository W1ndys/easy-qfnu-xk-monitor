# QFNU CAS 登录配置
# 复制此文件为 .env 并填写真实信息

# 教务登录账号信息
QFNU_USERNAME=2023000001
QFNU_PASSWORD=your_password

# OneBot HTTP 推送配置
ONEBOT_URL=http://127.0.0.1:3000
ONEBOT_TOKEN=

# 推送目标群号（逗号分隔）
GROUP_LIST=123456,789012

# 监控课程号（逗号分隔）
COURSE_LIST=A001,B002

# 已弃用：当前版本由外部计划任务控制执行间隔
POLL_INTERVAL=2

# 日志目录（可选，默认 logs）
LOG_DIR=logs

# 日志保留天数（可选，默认 30）
LOG_MAX_AGE_DAYS=30
